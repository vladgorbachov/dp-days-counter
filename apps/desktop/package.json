{
  "name": "dp-days-counter",
  "version": "2.0.0",
  "description": "Professional application for tracking Dynamic Positioning days and hours on vessels",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run build:watch\" \"npm run electron:dev\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json && npm run copy:static",
    "copy:static": "node scripts/copy-static.js",
    "build:watch": "concurrently \"npm run build:main:watch\" \"npm run build:renderer:watch\"",
    "build:main:watch": "tsc -p tsconfig.main.json --watch",
    "build:renderer:watch": "tsc -p tsconfig.renderer.json --watch",
    "electron:dev": "wait-on dist/main/main.js && electron .",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder",
    "dist": "npm run build && node scripts/verify-installer-nsh.js && electron-builder --publish=never",
    "postinstall": "electron-builder install-app-deps",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug"
  },
  "keywords": [
    "electron",
    "typescript",
    "dp",
    "dynamic-positioning",
    "vessel",
    "hours-counter"
  ],
  "author": "DeLion Software",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^20.19.9",
    "concurrently": "^8.2.2",
    "electron": "^27.1.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-log": "^5.1.2",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.delion.dp-days-counter",
    "productName": "DP Days Counter",
    "directories": {
      "output": "release"
    },
    "artifactName": "DP-Days-Counter-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "perMachine": false,
      "include": "installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vladgorbachov",
        "repo": "dp-days-counter",
        "releaseType": "release"
      }
    ]
  }
}
